# =============================================================================
# NexCMS Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- App ---
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://nexcms:nexcms@localhost:5432/nexcms_dev

# --- Auth (JWT) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_random_64_byte_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Media Storage ---
# Strategy: 'local' | 's3'
MEDIA_STORAGE=local
MEDIA_LOCAL_PATH=./uploads

# S3-compatible (only if MEDIA_STORAGE=s3)
# Works with AWS S3, MinIO, Backblaze B2, Cloudflare R2, etc.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# --- Email (for notifications, password reset) ---
# Strategy: 'smtp' | 'resend' | 'none'
EMAIL_STRATEGY=none
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
# OR
RESEND_API_KEY=

# --- Admin Panel ---
ADMIN_URL=http://localhost:5173

# --- Site ---
# Set after running the installer wizard
SITE_NAME=My NexCMS Site
SITE_URL=http://localhost:3000
